.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules
jspm_packages

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Build directory
dist

# webstorm
.idea

*.bck

# Ignore raw JSON data dumps, but not project config files
server/data/*.json
infra/.env

